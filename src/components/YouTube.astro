---
/**
 * YouTube Component
 * Embeds a YouTube video with responsive sizing
 * 
 * Usage:
 * import YouTube from '@/components/YouTube.astro';
 * <YouTube id="dQw4w9WgXcQ" title="My Video" />
 */

interface Props {
  /** YouTube video ID (from youtube.com/watch?v=ID) */
  id: string;
  /** Video title for accessibility */
  title?: string;
  /** Container class for custom styling */
  class?: string;
}

const { id, title = 'YouTube video player', class: className = '' } = Astro.props;
---

<div class={`youtube-container ${className}`}>
  <iframe
    src={`https://www.youtube.com/embed/${id}`}
    title={title}
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
  />
</div>

<style>
  .youtube-container {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
    border-radius: 0.5rem; /* rounded-lg */
  }

  .youtube-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
