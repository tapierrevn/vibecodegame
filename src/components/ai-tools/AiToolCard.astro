---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  name: string;
  description: string;
  website: string;
  featured: boolean;
  logo: string;
  href: string;
}

const { slug, name, description, website, featured, logo, href } = Astro.props;

const aiToolImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/ai-tools/*/*.{png,jpg,jpeg,webp,avif,svg}',
  { eager: true },
);
const imageLogo = Object.entries(aiToolImages).find(([path]) => path.includes(`/ai-tools/${slug}/`))?.[1]
  .default;

---

<article
  class:list={[
    'group relative isolate h-full rounded-lg border bg-background p-6 ring-1 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-md overflow-hidden',
    featured
      ? 'featured-ai-tool-card border-2 border-brand-400/85 ring-brand-400/40 hover:border-brand-300'
      : 'border-brand-500/30 ring-brand-500/20 hover:border-brand-500',
  ]}
>
  <a href={href} class="block">
    <div class="mb-4 flex items-start justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-lg border border-border bg-background-secondary">
          {
            imageLogo ? (
              <img src={imageLogo.src} alt={`${name} logo`} class="h-8 w-8 object-contain" loading="lazy" />
            ) : (
              <Icon name={logo} size="lg" class="text-foreground" />
            )
          }
        </div>
        <div>
          <h2 class="font-display text-xl font-bold text-foreground transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
            {name}
          </h2>
        </div>
      </div>
      {featured && (
        <span class="inline-flex items-center rounded-full bg-brand-500/10 px-2.5 py-0.5 text-xs font-medium text-brand-600 ring-1 ring-inset ring-brand-500/30 dark:text-brand-400">
          Featured
        </span>
      )}
    </div>
  </a>

  <p class="mb-4 text-sm text-foreground-muted">{description}</p>

  <a href={website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-brand-600 transition-colors hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300">
    Visit website
    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7m0 0v7m0-7L10 14" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10v11h11" />
    </svg>
  </a>
</article>

<style>
  .featured-ai-tool-card::before {
    content: '';
    position: absolute;
    inset: -8%;
    pointer-events: none;
    z-index: 1;
    transform: translateX(-150%) rotate(10deg);
    background: linear-gradient(105deg, transparent 30%, rgb(255 255 255 / 0.78) 50%, transparent 70%);
    opacity: 0;
    animation: featuredAiShine 2.2s linear infinite;
  }

  .featured-ai-tool-card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(circle at 12% 18%, rgb(59 130 246 / 0.22), transparent 62%),
      linear-gradient(145deg, rgb(59 130 246 / 0.1), transparent 55%);
  }

  .featured-ai-tool-card {
    box-shadow: 0 0 0 1px rgb(96 165 250 / 0.5), 0 0 22px rgb(59 130 246 / 0.28);
  }

  @keyframes featuredAiShine {
    0% {
      transform: translateX(-150%) rotate(10deg);
      opacity: 0;
    }
    20% {
      opacity: 0.7;
    }
    40% {
      opacity: 0.18;
    }
    48%,
    100% {
      transform: translateX(150%) rotate(10deg);
      opacity: 0;
    }
  }
</style>
