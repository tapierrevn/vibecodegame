---
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  slug: string;
  name: string;
  description: string;
  website: string;
  featured: boolean;
  usability: 'Easy' | 'Medium' | 'Hard';
  logo: string;
  href: string;
}

const { slug, name, description, website, featured, usability, logo, href } = Astro.props;

const aiToolImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/ai-tools/*/*.{png,jpg,jpeg,webp,avif,svg}',
  { eager: true },
);
const imageLogo = Object.entries(aiToolImages).find(([path]) => path.includes(`/ai-tools/${slug}/`))?.[1]
  .default;

const usabilityClassMap: Record<Props['usability'], string> = {
  Easy: 'bg-green-500/10 text-green-600 ring-green-500/30 dark:text-green-400',
  Medium: 'bg-amber-500/10 text-amber-600 ring-amber-500/30 dark:text-amber-400',
  Hard: 'bg-red-500/10 text-red-600 ring-red-500/30 dark:text-red-400',
};
---

<article class="group h-full rounded-lg border border-brand-500/30 bg-background p-6 ring-1 ring-brand-500/20 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-brand-500 hover:shadow-md">
  <a href={href} class="block">
    <div class="mb-4 flex items-start justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="inline-flex h-12 w-12 items-center justify-center rounded-lg border border-border bg-background-secondary">
          {
            imageLogo ? (
              <img src={imageLogo.src} alt={`${name} logo`} class="h-8 w-8 object-contain" loading="lazy" />
            ) : (
              <Icon name={logo} size="lg" class="text-foreground" />
            )
          }
        </div>
        <div>
          <h2 class="font-display text-xl font-bold text-foreground transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
            {name}
          </h2>
          <span class={`mt-1 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset ${usabilityClassMap[usability]}`}>
            {usability}
          </span>
        </div>
      </div>
      {featured && (
        <span class="inline-flex items-center rounded-full bg-brand-500/10 px-2.5 py-0.5 text-xs font-medium text-brand-600 ring-1 ring-inset ring-brand-500/30 dark:text-brand-400">
          Featured
        </span>
      )}
    </div>
  </a>

  <p class="mb-4 text-sm text-foreground-muted">{description}</p>

  <a href={website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-brand-600 transition-colors hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300">
    Visit website
    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7m0 0v7m0-7L10 14" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10v11h11" />
    </svg>
  </a>
</article>
