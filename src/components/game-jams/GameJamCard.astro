---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  getGameJamStatus,
  gameJamCardArticleBaseClass,
  gameJamCardBorderClasses,
  type GameJamStatus,
} from '@/lib/game-jams-status';

interface Props {
  slug: string;
  name: string;
  description: string;
  startDate: Date;
  endDate: Date;
  participationLink: string;
  place: string;
  country: string;
  organizers: string[];
  featured?: boolean;
  image: ImageMetadata;
  imageAlt?: string;
}

const {
  slug,
  name,
  description,
  startDate,
  endDate,
  participationLink,
  place,
  country,
  organizers,
  featured = false,
  image,
  imageAlt,
} = Astro.props;

const now = new Date();
const status: GameJamStatus = getGameJamStatus(startDate, endDate, now);

const formattedStart = startDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
const formattedEnd = endDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const cardStatusClasses = gameJamCardBorderClasses[status];
---

<article
  data-game-jam-card
  data-jam-start={startDate.toISOString()}
  data-jam-end={endDate.toISOString()}
  class:list={[gameJamCardArticleBaseClass, cardStatusClasses]}
>
  <a href={`/game-jams/${slug}`} class="block">
    <div class="relative mb-4 overflow-hidden rounded-md">
      <Image
        src={image}
        alt={imageAlt || name}
        widths={[480, 720, 960]}
        sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 420px"
        class="aspect-[21/7] w-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
      {featured && (
        <span class="absolute left-3 top-3 inline-flex items-center rounded-full bg-brand-500 px-2.5 py-1 text-xs font-semibold text-white">
          Featured
        </span>
      )}
      <span
        data-jam-status-badge="in_progress"
        hidden={status !== 'in_progress'}
        class="absolute right-3 top-3 inline-flex min-w-[132px] items-center justify-center rounded-full bg-emerald-500 px-4 py-1.5 text-sm font-semibold text-white"
      >
        In progress
      </span>
      <span
        data-jam-status-badge="coming_soon"
        hidden={status !== 'coming_soon'}
        class:list={[
          'absolute right-3 top-3 inline-flex min-w-[132px] items-center justify-center rounded-full bg-violet-600 px-4 py-1.5 text-sm font-semibold text-white',
          status === 'coming_soon' && 'jam-coming-soon-tag',
        ]}
      >
        Coming Soon
      </span>
      <span
        data-jam-status-badge="past"
        hidden={status !== 'past'}
        class="absolute right-3 top-3 inline-flex min-w-[132px] items-center justify-center rounded-full bg-slate-500 px-4 py-1.5 text-sm font-semibold text-white"
      >
        Finished
      </span>
    </div>

    <div class="mb-2 flex items-start justify-between gap-3">
      <h2 class="font-display text-xl font-bold text-foreground transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
        {name}
      </h2>
    </div>

    <p class="mb-4 line-clamp-3 text-foreground-muted">{description}</p>
  </a>

  <div class="space-y-2 text-sm text-foreground-subtle">
    <p>
      <span class="font-medium text-foreground">Dates:</span>
      <time datetime={startDate.toISOString()}>{formattedStart}</time>
      {' - '}
      <time datetime={endDate.toISOString()}>{formattedEnd}</time>
    </p>
    <p><span class="font-medium text-foreground">Location:</span> {place}, {country}</p>
    {organizers.length > 0 && (
      <p>
        <span class="font-medium text-foreground">Organizers:</span> {organizers.join(', ')}
      </p>
    )}
  </div>

  <div class="mt-4 flex justify-end">
    <div data-jam-cta="coming_soon" hidden={status !== 'coming_soon'}>
      <a
        href={participationLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-full border border-violet-600 bg-violet-600 px-5 py-2.5 text-base font-semibold text-white transition-colors hover:border-violet-700 hover:bg-violet-700"
      >
        Participate Now
        <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <div data-jam-cta="past" hidden={status !== 'past'}>
      <a
        href={`/game-jams/${slug}`}
        class="inline-flex items-center justify-center rounded-full border border-slate-500 bg-slate-500 px-4 py-2 text-sm font-semibold text-white transition-colors hover:border-slate-600 hover:bg-slate-600"
      >
        Show Results
        <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>

<style>
  .jam-coming-soon-tag {
    animation: jamComingSoonPulse 1.8s ease-in-out infinite;
  }

  @keyframes jamComingSoonPulse {
    0%,
    100% {
      transform: scale(1);
      filter: brightness(1);
    }
    50% {
      transform: scale(1.06);
      filter: brightness(1.1);
    }
  }
</style>
