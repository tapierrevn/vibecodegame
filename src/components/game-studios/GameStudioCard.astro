---
interface Props {
  name: string;
  description: string;
  href: string;
  logo: string;
  creationYear: string;
  website: string;
  headquarterAddress: string;
  aiTools: string[];
  gamesGenre: string[];
  gameEngine: string[];
}

const { name, description, href, logo, creationYear, website, headquarterAddress, aiTools, gamesGenre, gameEngine } = Astro.props;
---

<article class="group h-full rounded-lg border border-brand-500/30 bg-background p-6 ring-1 ring-brand-500/20 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:border-brand-500 hover:shadow-md">
  <a href={href} class="block">
    <div class="mb-4 flex items-center gap-4">
      <img
        src={logo}
        alt={`${name} logo`}
        class="h-16 w-16 rounded-xl border border-border bg-background-secondary object-cover p-2 ring-2 ring-brand-500/20"
        loading="lazy"
      />
      <div class="min-w-0">
        <h2 class="font-display text-xl font-bold text-foreground transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
          {name}
        </h2>
        <p class="text-sm text-foreground-muted">Founded {creationYear}</p>
      </div>
    </div>
    <p class="mb-4 line-clamp-3 text-sm text-foreground-muted">{description}</p>
  </a>

  <div class="space-y-3 text-xs">
    <div>
      <p class="mb-1 font-medium text-foreground-muted">Headquarters</p>
      <p class="text-foreground-subtle">{headquarterAddress}</p>
    </div>
    <div>
      <p class="mb-1 font-medium text-foreground-muted">Website</p>
      <a href={website} target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300">
        {website}
      </a>
    </div>

    {gamesGenre.length > 0 && (
      <div>
        <p class="mb-1 font-medium text-foreground-muted">Game Genres</p>
        <div class="flex flex-wrap gap-2">
          {gamesGenre.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}

    {aiTools.length > 0 && (
      <div>
        <p class="mb-1 font-medium text-foreground-muted">AI Tools</p>
        <div class="flex flex-wrap gap-2">
          {aiTools.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}

    {gameEngine.length > 0 && (
      <div>
        <p class="mb-1 font-medium text-foreground-muted">Game Engines</p>
        <div class="flex flex-wrap gap-2">
          {gameEngine.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </div>
</article>
