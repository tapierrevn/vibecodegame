---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BlogImageSVG from '@/components/blog/BlogImageSVG.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import type { GamePlatformValue } from '@/lib/game-meta';
import { gamePlatformIcon, publishedAtToLongMonthYear, publishedAtToIsoDateLocal } from '@/lib/game-meta';

interface Props {
  title: string;
  description: string;
  href: string;
  developerName: string;
  studio?: string;
  developerProfileUrl: string;
  genre: string[];
  gameEngine: string[];
  aiTools: string[];
  communityScore: number;
  playUrl: string;
  publishedAt?: Date;
  offersPrice?: 0 | 1;
  gamePlatform?: GamePlatformValue[];
  showGenre?: boolean;
  showEngine?: boolean;
  showAiTools?: boolean;
  image?: ImageMetadata;
  svgSlug?: string;
  leaderboardRank?: 1 | 2 | 3;
}

const {
  title,
  description,
  href,
  developerName,
  studio,
  developerProfileUrl,
  genre,
  gameEngine,
  aiTools,
  communityScore,
  publishedAt,
  offersPrice = 0,
  gamePlatform = ['Web Browser'],
  showGenre = true,
  showEngine = true,
  showAiTools = true,
  image,
  svgSlug,
  leaderboardRank,
} = Astro.props;

const releaseDate = publishedAtToLongMonthYear(publishedAt);
const releaseDateTime = publishedAtToIsoDateLocal(publishedAt);
const medalStyles: Record<1 | 2 | 3, string> = {
  1: 'border-4 border-amber-400/90 ring-amber-400/45 hover:border-amber-300',
  2: 'border-4 border-slate-300/90 ring-slate-300/45 hover:border-slate-200',
  3: 'border-4 border-orange-500/90 ring-orange-500/45 hover:border-orange-400',
};
const medalTagStyles: Record<1 | 2 | 3, string> = {
  1: 'bg-amber-100 text-amber-900 dark:bg-amber-900/40 dark:text-amber-200',
  2: 'bg-slate-200 text-slate-800 dark:bg-slate-800/60 dark:text-slate-200',
  3: 'bg-orange-200 text-orange-900 dark:bg-orange-900/45 dark:text-orange-200',
};
const medalBorderClass = leaderboardRank ? medalStyles[leaderboardRank] : null;
const medalTagClass = leaderboardRank ? medalTagStyles[leaderboardRank] : null;
const medalCardClass = leaderboardRank ? `medal-rank-card medal-rank-${leaderboardRank}` : null;
---

<article
  class:list={[
    'group relative isolate h-full rounded-lg border bg-background p-6 ring-1 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-md flex flex-col overflow-hidden',
    medalBorderClass ?? 'border-brand-500/30 ring-brand-500/20 hover:border-brand-500',
    medalCardClass,
  ]}
>
  <a href={href} class="relative z-10 block">
    <div
      class="relative mb-4 overflow-hidden rounded-md
        bg-background-secondary bg-gradient-to-br from-brand-100/65 to-transparent dark:from-brand-900/60 dark:to-brand-600/25"
      style="color: var(--brand-500);"
    >
      {svgSlug ? (
        <div class="transition-transform duration-300 group-hover:scale-105">
          <BlogImageSVG slug={svgSlug} title={title} />
        </div>
      ) : image ? (
        <Image
          src={image}
          alt={title}
          widths={[320, 640, 960]}
          sizes="(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 400px"
          class="aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="aspect-video w-full" />
      )}
    </div>

    <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
      <h2 class="font-display text-xl font-bold text-foreground transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
        {title}
      </h2>
      <div class="flex flex-wrap items-center gap-2">
        {leaderboardRank && (
          <span class:list={['inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-bold', medalTagClass]}>
            Top {leaderboardRank}
          </span>
        )}
        <span
          class:list={[
            'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold ring-1 ring-inset',
            offersPrice === 0
              ? 'bg-emerald-100 text-emerald-800 ring-emerald-200 dark:bg-emerald-900/40 dark:text-emerald-200 dark:ring-emerald-800'
              : 'bg-orange-100 text-orange-800 ring-orange-200 dark:bg-orange-900/40 dark:text-orange-200 dark:ring-orange-800',
          ]}
          title={offersPrice === 0 ? 'Free to play' : 'Paid'}
        >
          {offersPrice === 0 ? 'Free' : 'Paid'}
        </span>
        <span
          class="inline-flex items-center gap-1 rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-semibold text-brand-800 dark:bg-brand-900/40 dark:text-brand-200"
          title="Community score"
        >
          <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.719c-.783-.57-.38-1.81.588-1.81H7.03a1 1 0 00.95-.69l1.07-3.292z" />
          </svg>
          {communityScore}/100
        </span>
      </div>
    </div>

    <p class="text-foreground-muted line-clamp-2 mb-3">
      {description}
    </p>
  </a>

  <div class="relative z-10 mb-3 text-sm mt-auto">
    <span class="text-foreground-subtle">Developer: </span>
    <a
      href={developerProfileUrl}
      class="font-medium text-brand-600 underline-offset-2 hover:underline dark:text-brand-400"
    >
      {developerName}
    </a>
    {studio && <span class="text-foreground-subtle"> at {studio}</span>}
  </div>

  <div class="relative z-10 text-sm text-foreground-subtle">
    {
      releaseDate && releaseDateTime && (
        <time datetime={releaseDateTime} class="mb-4 flex items-center gap-1">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
            />
          </svg>
          Release Date: {releaseDate}
        </time>
      )
    }
    {
      gamePlatform.length > 0 && (
        <div>
          <p class="mb-1 text-xs font-medium text-foreground-muted">Platforms</p>
          <span class="flex items-center gap-1.5" title={gamePlatform.join(', ')}>
            {gamePlatform.map((p) => (
              <Icon name={gamePlatformIcon(p)} size="sm" class="text-foreground-muted" aria-label={p} />
            ))}
          </span>
        </div>
      )
    }
  </div>

  {
    showEngine && gameEngine.length > 0 && (
      <div class="relative z-10 mt-3">
        <p class="mb-1 text-xs font-medium text-foreground-muted">Engine</p>
        <div class="flex flex-wrap gap-2">
          {gameEngine.map((engine) => (
            <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
              {engine}
            </span>
          ))}
        </div>
      </div>
    )
  }

  {
    showGenre && genre.length > 0 && (
      <div class="relative z-10 mt-3">
        <p class="mb-1 text-xs font-medium text-foreground-muted">Genre</p>
        <div class="flex flex-wrap gap-2">
          {genre.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )
  }

  {
    showAiTools && aiTools.length > 0 && (
      <div class="relative z-10 mt-3">
        <p class="mb-1 text-xs font-medium text-foreground-muted">Built with</p>
        <div class="flex flex-wrap items-center gap-2">
          {aiTools.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border transition-colors group-hover:bg-brand-50 group-hover:text-brand-700 group-hover:ring-brand-200 dark:group-hover:bg-brand-900/20 dark:group-hover:text-brand-400 dark:group-hover:ring-brand-800">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )
  }

  <a
    href={href}
    class="absolute inset-x-6 bottom-6 z-30 inline-flex items-center justify-center gap-2 rounded-md bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-lg transition-all duration-200 ease-out translate-y-6 opacity-0 pointer-events-none group-hover:translate-y-0 group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100 group-focus-within:pointer-events-auto hover:bg-brand-500 dark:bg-brand-500 dark:hover:bg-brand-400"
  >
    See Details
    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14 3h7m0 0v7m0-7L10 14" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10v11h11" />
    </svg>
  </a>
</article>

<style>
  .medal-rank-card::before {
    content: '';
    position: absolute;
    inset: -8%;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transform: translateX(-160%) rotate(10deg);
    background: linear-gradient(105deg, transparent 28%, rgb(255 255 255 / 0.95) 50%, transparent 72%);
    filter: blur(0.2px);
    animation: medalShineSweep 1.8s linear infinite;
  }

  .medal-rank-card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0.5;
  }

  .medal-rank-1 {
    box-shadow: 0 0 0 1px rgb(251 191 36 / 0.55), 0 0 24px rgb(251 191 36 / 0.34);
    animation: medalGlowGold 1.9s ease-in-out infinite;
  }
  .medal-rank-1::after {
    background: radial-gradient(circle at 15% 20%, rgb(251 191 36 / 0.42), transparent 62%),
      linear-gradient(140deg, rgb(251 191 36 / 0.24), transparent 55%);
  }

  .medal-rank-2 {
    box-shadow: 0 0 0 1px rgb(203 213 225 / 0.6), 0 0 22px rgb(203 213 225 / 0.3);
    animation: medalGlowSilver 2.1s ease-in-out infinite;
  }
  .medal-rank-2::after {
    opacity: 0.62;
    background: radial-gradient(circle at 15% 20%, rgb(226 232 240 / 0.88), transparent 62%),
      linear-gradient(140deg, rgb(226 232 240 / 0.62), transparent 55%),
      linear-gradient(180deg, rgb(148 163 184 / 0.24), rgb(148 163 184 / 0.12));
  }

  .medal-rank-3 {
    box-shadow: 0 0 0 1px rgb(249 115 22 / 0.55), 0 0 22px rgb(249 115 22 / 0.3);
    animation: medalGlowBronze 2s ease-in-out infinite;
  }
  .medal-rank-3::after {
    background: radial-gradient(circle at 15% 20%, rgb(249 115 22 / 0.4), transparent 62%),
      linear-gradient(140deg, rgb(251 146 60 / 0.2), transparent 55%);
  }

  @keyframes medalShineSweep {
    0% {
      transform: translateX(-160%) rotate(10deg);
      opacity: 0;
    }
    20% {
      opacity: 0.82;
    }
    34% {
      opacity: 0.3;
    }
    45% {
      transform: translateX(165%) rotate(10deg);
      opacity: 0;
    }
    100% {
      transform: translateX(165%) rotate(10deg);
      opacity: 0;
    }
  }

  @keyframes medalGlowGold {
    0%,
    100% {
      box-shadow: 0 0 0 1px rgb(251 191 36 / 0.5), 0 0 20px rgb(251 191 36 / 0.28);
    }
    50% {
      box-shadow: 0 0 0 1px rgb(251 191 36 / 0.75), 0 0 30px rgb(251 191 36 / 0.45);
    }
  }

  @keyframes medalGlowSilver {
    0%,
    100% {
      box-shadow: 0 0 0 1px rgb(203 213 225 / 0.5), 0 0 18px rgb(203 213 225 / 0.24);
    }
    50% {
      box-shadow: 0 0 0 1px rgb(226 232 240 / 0.78), 0 0 28px rgb(226 232 240 / 0.42);
    }
  }

  @keyframes medalGlowBronze {
    0%,
    100% {
      box-shadow: 0 0 0 1px rgb(249 115 22 / 0.5), 0 0 18px rgb(249 115 22 / 0.24);
    }
    50% {
      box-shadow: 0 0 0 1px rgb(251 146 60 / 0.75), 0 0 28px rgb(251 146 60 / 0.4);
    }
  }
</style>
