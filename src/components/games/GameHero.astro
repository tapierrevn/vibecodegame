---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { formatDate } from '@/lib/utils';
import BlogImageSVG from '@/components/blog/BlogImageSVG.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

interface Props {
  title: string;
  description: string;
  developerName: string;
  developerProfileUrl: string;
  genre: string[];
  aiTools: string[];
  playUrl: string;
  communityScore: number;
  publishedAt?: string;
  updatedAt?: Date;
  image?: ImageMetadata;
  imageAlt?: string;
  svgSlug?: string;
}

const {
  title,
  description,
  developerName,
  developerProfileUrl,
  genre,
  aiTools,
  playUrl,
  communityScore,
  publishedAt,
  updatedAt,
  image,
  imageAlt,
  svgSlug,
} = Astro.props;

function formatReleaseDate(value?: string): string | null {
  if (!value) return null;
  const match = /^(0[1-9]|1[0-2])-(\d{4})$/.exec(value);
  if (!match) return value;

  const monthNames = [
    'January',
    'February',
    'March',
    'April',
    'May',
    'June',
    'July',
    'August',
    'September',
    'October',
    'November',
    'December',
  ];
  const monthIndex = Number(match[1]) - 1;
  return `${monthNames[monthIndex]} ${match[2]}`;
}

const formattedReleaseDate = formatReleaseDate(publishedAt);
---

<header class="relative overflow-hidden pt-[var(--space-page-top-sm)] pb-[var(--space-stack-md)]">
  <div class="relative mx-auto max-w-4xl px-6 animate-hero-slide-up">
    {
      (svgSlug || image) && (
        <div class="relative mx-auto max-w-5xl mb-[var(--space-section-sm)] animate-hero-slide-up [animation-delay:200ms]">
          {svgSlug ? (
            <div
              class="relative overflow-hidden rounded-xl border border-border shadow-2xl
            bg-gradient-to-br from-brand-100/50 to-brand-50/30 dark:from-brand-900/50 dark:to-brand-600/30"
              style="color: var(--brand-500);"
            >
              <BlogImageSVG slug={svgSlug} title={imageAlt || title} />
            </div>
          ) : image ? (
            <div class="relative overflow-hidden rounded-xl border border-border shadow-2xl">
              <Image
                src={image}
                alt={imageAlt || title}
                layout="full-width"
                widths={[640, 960, 1280, 1920]}
                sizes="100vw"
                class="aspect-video w-full object-cover"
                loading="eager"
              />
            </div>
          ) : null}
        </div>
      )
    }


    <h1 class="font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl lg:text-6xl mb-[var(--space-heading-gap)]">
      {title}
    </h1>

    <p class="text-xl text-foreground-muted leading-relaxed max-w-3xl mb-[var(--space-stack-lg)]">
      {description}
    </p>

    <div class="flex flex-wrap items-center gap-4 mb-[var(--space-stack-lg)]">
      <Button
        size="lg"
        href={playUrl}
        class="!bg-purple-600 !text-white hover:!bg-purple-500 dark:!bg-purple-500 dark:hover:!bg-purple-400"
      >
        Play
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>

    <div class="flex flex-wrap items-center gap-[var(--space-stack-lg)] text-sm text-foreground-muted mb-[var(--space-heading-gap)]">
      {
        publishedAt && (
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"
              />
            </svg>
            <time datetime={`${publishedAt.slice(3)}-${publishedAt.slice(0, 2)}-01`}>
              Release Date: {formattedReleaseDate}
            </time>
          </div>
        )
      }
      {
        updatedAt && (
          <>
            <div class="h-8 w-px bg-border hidden md:block" />
            <div class="flex items-center gap-2">
              <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"
                />
              </svg>
              <time datetime={updatedAt.toISOString()}>Updated {formatDate(updatedAt)}</time>
            </div>
          </>
        )
      }
    </div>

    <div class="mb-4 flex flex-wrap items-center gap-3">
      <span
        class="inline-flex items-center rounded-full bg-brand-100 px-3 py-1 text-sm font-semibold text-brand-800 dark:bg-brand-900/40 dark:text-brand-200"
        title="Community score"
      >
        <Icon name="star" size="sm" class="mr-1" />
        {communityScore}/100
      </span>
    </div>
    <div class="mb-4 flex flex-wrap items-center gap-2">
      <span class="text-sm font-semibold text-foreground-muted">Developer:</span>
      <a
        href={developerProfileUrl}
        class="inline-flex items-center gap-2 text-sm font-medium text-brand-600 hover:text-brand-500 dark:text-brand-400"
      >
        {developerName}
        <Icon name="arrow-up-right" size="sm" class="opacity-70" />
      </a>
    </div>

    {
      genre.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          <span class="text-sm font-semibold text-foreground-muted w-full">Genre</span>
          {genre.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-brand-100 dark:bg-brand-900/30 px-3 py-1 text-xs font-semibold text-brand-700 dark:text-brand-300 ring-1 ring-inset ring-brand-200 dark:ring-brand-800">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    {
      aiTools.length > 0 && (
        <div class="mb-2 flex flex-wrap gap-2">
          <span class="text-sm font-semibold text-foreground-muted w-full">Built with</span>
          {aiTools.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-background-secondary px-3 py-1 text-xs font-semibold text-foreground-muted ring-1 ring-inset ring-border">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </div>

</header>
