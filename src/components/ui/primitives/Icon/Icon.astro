---
/**
 * Icon component
 * UI icons  → Lucide  (lucide.dev)
 * Brand/social icons → Simple Icons (simpleicons.org)
 *
 * Same public API as before — callers pass the short name (e.g. "arrow-right",
 * "github", "x-twitter"). This wrapper resolves it to the correct Iconify set.
 */
import { Icon as AstroIcon } from 'astro-icon/components';
import { cn } from '@/lib/cn';

interface Props {
  name: string;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
  strokeWidth?: number;
  [key: string]: unknown;
}

const { name, size = 'md', class: className, strokeWidth = 2, ...attrs } = Astro.props;

const sizes: Record<string, string> = {
  xs: 'w-3 h-3',
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
  xl: 'w-8 h-8',
};

/**
 * Maps short legacy names → fully-qualified Iconify names.
 * Social / brand icons use simple-icons; everything else uses lucide.
 */
const iconMap: Record<string, string> = {
  // Social & brand → Simple Icons
  github:           'simple-icons:github',
  'x-twitter':      'simple-icons:x',
  twitter:          'simple-icons:x',
  instagram:        'simple-icons:instagram',
  linkedin:         'simple-icons:linkedin',
  bluesky:          'simple-icons:bluesky',
  // Tech stack → Simple Icons
  'brand-astro':      'simple-icons:astro',
  'brand-tailwind':   'simple-icons:tailwindcss',
  'brand-typescript': 'simple-icons:typescript',
  'brand-react':      'simple-icons:react',
  'brand-mdx':        'simple-icons:mdx',
  'brand-claude':     'simple-icons:anthropic',
};

const resolvedName = iconMap[name] ?? `lucide:${name}`;
const isSimpleIcon = resolvedName.startsWith('simple-icons:');

// Stroke-only GitHub cat path (no circle border) — same line-art style as Lucide icons.
const GITHUB_PATH = "M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C2.6 4.4 1.5 4.7 1.5 4.7a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 .1 11.1c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21";
---

{name === 'github' ? (
  <svg
    class={cn(sizes[size], 'shrink-0', className)}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    {...attrs}
  >
    <path d={GITHUB_PATH} />
  </svg>
) : (
  <AstroIcon
    name={resolvedName}
    class={cn(sizes[size], 'shrink-0', className)}
    aria-hidden="true"
    stroke-width={isSimpleIcon ? undefined : strokeWidth}
    {...attrs}
  />
)}
