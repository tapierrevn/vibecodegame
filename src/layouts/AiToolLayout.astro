---
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import siteConfig from '@/config/site.config';
import PageLayout from '@/layouts/PageLayout.astro';
import GameCard from '@/components/games/GameCard.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { gameEntryToPath } from '@/lib/games-similar';

interface Props {
  slug: string;
  name: string;
  description: string;
  website: string;
  featured: boolean;
  logo: string;
  relatedGames: CollectionEntry<'games'>[];
}

const { slug, name, description, website, featured, logo, relatedGames } = Astro.props;
const aiToolImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/ai-tools/*/*.{png,jpg,jpeg,webp,avif,svg}',
  { eager: true },
);
const imageLogo = Object.entries(aiToolImages).find(([path]) => path.includes(`/ai-tools/${slug}/`))?.[1]
  .default;
const pageTitle = `${name} AI Tool Profile | Tutorials, Links & Games | ${siteConfig.name}`;
const pageDescription = `Explore ${name}: profile details, official links, tutorials, and vibe-coded games made with this AI tool.`;
const fullUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = slug ? `/og/ai-tools/${slug}.png` : siteConfig.ogImage;

---

<PageLayout title={pageTitle} description={pageDescription} image={ogImage} imageAlt={`${name} AI tool logo`} showScrollProgress eagerReveal>
  <section class="border-t border-border bg-background-secondary py-[var(--space-section-sm)]">
    <div class="mx-auto max-w-4xl px-6 text-center">
      <div class="mx-auto mb-5 inline-flex h-20 w-20 items-center justify-center rounded-2xl border border-border bg-background ring-4 ring-brand-500/20">
        {
          imageLogo ? (
            <img src={imageLogo.src} alt={`${name} logo`} class="h-14 w-14 object-contain" loading="eager" />
          ) : (
            <Icon name={logo} size="xl" class="text-foreground" />
          )
        }
      </div>
      <h1 class="font-display text-4xl font-bold text-foreground">{name}</h1>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-foreground-muted">{description}</p>

      <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
        {featured && (
          <span class="inline-flex items-center rounded-full bg-brand-500/10 px-2.5 py-0.5 text-xs font-medium text-brand-600 ring-1 ring-inset ring-brand-500/30 dark:text-brand-400">
            Featured
          </span>
        )}
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
        >
          Official website
        </a>
      </div>
    </div>
  </section>

  <article class="border-t border-border bg-background py-[var(--space-section-sm)]">
    <div class="prose prose-lg mx-auto max-w-4xl px-6">
      <slot />
    </div>
  </article>

  <section class="border-t border-border bg-background-secondary py-[var(--space-section-sm)]">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-6 font-display text-3xl font-bold text-foreground">Games made with {name}</h2>
      {relatedGames.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {relatedGames.map((game) => (
            <GameCard
              title={game.data.title}
              description={game.data.description}
              href={gameEntryToPath(game)}
              developerName={game.data.developerName}
              studio={game.data.studio}
              developerProfileUrl={game.data.developerProfileUrl}
              genre={game.data.genre}
              gameEngine={game.data.gameEngine}
              aiTools={game.data.aiTools}
              communityScore={game.data.communityScore}
              playUrl={game.data.playUrl}
              publishedAt={game.data.publishedAt}
              offersPrice={game.data.offersPrice}
              gamePlatform={game.data.gamePlatform}
              image={game.data.image}
              svgSlug={game.data.svgSlug}
            />
          ))}
        </div>
      ) : (
        <p class="text-foreground-muted">No games are listed yet for this tool.</p>
      )}
    </div>
  </section>

  <section class="bg-background py-8 border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <a
          href="/ai-tools"
          class="text-brand-600 hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300 inline-flex items-center gap-2 text-sm font-medium transition-colors"
        >
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to AI Tools
        </a>
        <ShareButtons title={pageTitle} url={fullUrl} />
      </div>
    </div>
  </section>
</PageLayout>
