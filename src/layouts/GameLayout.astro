---
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import siteConfig from '@/config/site.config';
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import GameHero from '@/components/games/GameHero.astro';
import GameImageCarousel from '@/components/games/GameImageCarousel.astro';
import SimilarGamesByGenre from '@/components/games/SimilarGamesByGenre.astro';
import SimilarGamesByAI from '@/components/games/SimilarGamesByAI.astro';
import SimilarGamesByEngine from '@/components/games/SimilarGamesByEngine.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import YouTube from '@/components/YouTube.astro';
import { resolveSocialLinks } from '@/lib/utils';
import { createVideoGameSchema } from '@/lib/schema';
import {
  youtubeVideoIdFromUrl,
  publishedAtToIsoDateLocal,
  type GamePlatformValue,
  type GamePlayModeValue,
} from '@/lib/game-meta';

const socialLinks = siteConfig.socialLinks.map((url) => {
  let platform = 'link';
  if (url.includes('x.com') || url.includes('twitter.com')) platform = 'twitter';
  else if (url.includes('discord.gg')) platform = 'discord';
  else if (url.includes('youtube.com')) platform = 'youtube';
  else if (url.includes('github.com')) platform = 'github';
  else if (url.includes('linkedin.com')) platform = 'linkedin';
  else if (url.includes('instagram.com')) platform = 'instagram';
  return { platform, href: url };
});

const socialLinksForCTA = resolveSocialLinks(siteConfig.socialLinks);

interface Props {
  title: string;
  description: string;
  developerName: string;
  developerProfileUrl: string;
  genre: string[];
  gameEngine: string[];
  aiTools: string[];
  playUrl: string;
  communityScore: number;
  publishedAt?: Date;
  updatedAt?: Date;
  image?: ImageMetadata;
  imageAlt?: string;
  svgSlug?: string;
  playMode: GamePlayModeValue[];
  offersPrice: 0 | 1;
  applicationCategory: string;
  operatingSystem: GamePlatformValue[];
  gamePlatform: GamePlatformValue[];
  trailerUrl?: string;
  galleryImageUrls: string[];
  similarByGenre: CollectionEntry<'games'>[];
  similarByAI: CollectionEntry<'games'>[];
  similarByEngine: CollectionEntry<'games'>[];
}

const {
  title,
  description,
  developerName,
  developerProfileUrl,
  genre,
  gameEngine,
  aiTools,
  playUrl,
  communityScore,
  publishedAt,
  updatedAt,
  image,
  imageAlt,
  svgSlug,
  playMode,
  offersPrice,
  applicationCategory,
  operatingSystem,
  gamePlatform,
  trailerUrl,
  galleryImageUrls,
  similarByGenre,
  similarByAI,
  similarByEngine,
} = Astro.props;

const ogImage = image?.src || siteConfig.ogImage;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Vibe-Coded Games', href: '/vibe-coded-games' },
  { label: title },
];

const fullUrl = new URL(Astro.url.pathname, Astro.site).toString();

const articleTags = [...genre, ...aiTools];
const publishedDateForSchema = publishedAt;
const trailerId = youtubeVideoIdFromUrl(trailerUrl);
const hasSimilarByGenre = similarByGenre.length > 0;
const hasSimilarByAI = similarByAI.length > 0;
const hasSimilarByEngine = similarByEngine.length > 0;
const openGenreByDefault = hasSimilarByGenre;
const openAIByDefault = !hasSimilarByGenre && hasSimilarByAI;
const openEngineByDefault = !hasSimilarByGenre && !hasSimilarByAI && hasSimilarByEngine;
const schemaImageUrl = image?.src
  ? new URL(image.src, Astro.site ?? Astro.url.origin).href
  : undefined;

const videoGameSchema = createVideoGameSchema({
  name: title,
  description,
  url: fullUrl,
  image: schemaImageUrl,
  applicationCategory,
  operatingSystem,
  gamePlatform,
  playMode,
  offersPrice,
  playUrl,
  datePublished: publishedAtToIsoDateLocal(publishedAt),
  trailerYoutubeId: trailerId,
});
---

<BaseLayout
  title={`${title} — Vibe-Coded Games — ${siteConfig.name}`}
  description={description}
  image={ogImage}
  imageAlt={imageAlt || title}
  article={{
    publishedTime: publishedDateForSchema,
    modifiedTime: updatedAt,
    authors: [developerName],
    tags: articleTags,
  }}
>
  <JsonLd schema={videoGameSchema} />
  <Header
    slot="header"
    position="fixed"
    shape="floating"
    variant="default"
    colorScheme="default"
    size="lg"
    showCta={false}
    cta={{ label: 'Get in touch', href: '/contact' }}
    showThemeSelector={false}
    showScrollProgress={true}
    scrollProgressPosition="top"
  />

  <div class="min-h-screen pt-16">
    <GameHero
      title={title}
      description={description}
      developerName={developerName}
      developerProfileUrl={developerProfileUrl}
      genre={genre}
      gameEngine={gameEngine}
      aiTools={aiTools}
      playUrl={playUrl}
      communityScore={communityScore}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      image={image}
      imageAlt={imageAlt}
      svgSlug={svgSlug}
      playMode={playMode}
      offersPrice={offersPrice}
      gamePlatform={gamePlatform}
    />

    <article class="pt-4 pb-[var(--space-section-md)]">
      <div class="mx-auto max-w-4xl px-6">
        <Breadcrumbs items={breadcrumbs} class="mb-8" />

        {galleryImageUrls.length > 0 && <GameImageCarousel images={galleryImageUrls} title={title} />}

        {
          trailerId && (
            <section class="mb-8">
              <h2 class="mb-3 font-display text-2xl font-bold text-foreground">Game Trailer</h2>
              <YouTube id={trailerId} title={`${title} trailer`} />
            </section>
          )
        }

        <div class="prose prose-lg max-w-none">
          <slot />
        </div>

        <footer class="border-border mt-12 border-t pt-8" data-reveal>
          <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
            <a
              href="/vibe-coded-games"
              class="text-brand-600 hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300 inline-flex items-center gap-2 text-sm font-medium transition-colors"
            >
              <svg
                class="h-4 w-4"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              Back to Vibe-Coded Games
            </a>
            <ShareButtons title={title} url={fullUrl} />
          </div>
        </footer>
      </div>
    </article>

    {
      (hasSimilarByGenre || hasSimilarByAI || hasSimilarByEngine) && (
        <section class="mx-auto max-w-screen-xl px-6 border-t border-border" data-reveal>
          {
            hasSimilarByGenre && (
              <details name="similar-games" open={openGenreByDefault} class="group/accordion border-b border-border">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
                  <span class="font-display text-2xl font-bold text-foreground">
                    Similar Vibe-Coded Games by Genre ({similarByGenre.length})
                  </span>
                  <Icon
                    name="chevron-down"
                    size="sm"
                    class="text-foreground-muted transition-transform duration-200 group-open/accordion:rotate-180"
                  />
                </summary>
                <SimilarGamesByGenre games={similarByGenre} />
              </details>
            )
          }

          {
            hasSimilarByAI && (
              <details name="similar-games" open={openAIByDefault} class="group/accordion border-b border-border">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
                  <span class="font-display text-2xl font-bold text-foreground">
                    Similar Vibe-Coded Games by AI Tool ({similarByAI.length})
                  </span>
                  <Icon
                    name="chevron-down"
                    size="sm"
                    class="text-foreground-muted transition-transform duration-200 group-open/accordion:rotate-180"
                  />
                </summary>
                <SimilarGamesByAI games={similarByAI} />
              </details>
            )
          }

          {
            hasSimilarByEngine && (
              <details name="similar-games" open={openEngineByDefault} class="group/accordion border-b border-border">
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
                  <span class="font-display text-2xl font-bold text-foreground">
                    Similar Vibe-Coded Games by Game Engine ({similarByEngine.length})
                  </span>
                  <Icon
                    name="chevron-down"
                    size="sm"
                    class="text-foreground-muted transition-transform duration-200 group-open/accordion:rotate-180"
                  />
                </summary>
                <SimilarGamesByEngine games={similarByEngine} />
              </details>
            )
          }
        </section>
      )
    }

    <CTA variant="default" size="md" maxWidth="lg" glow={false} data-reveal class="bg-background-secondary">
      <h2 slot="heading" class="!text-4xl">Follow along</h2>
      <p slot="description" class="!text-lg text-balance">Stay in the loop — new games, tools, and updates.</p>

      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="/rss.xml"
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
        >
          <Icon name="rss" size="sm" />
          RSS Feed
        </a>
        {socialLinksForCTA.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
          >
            <Icon name={link.icon} size="sm" />
            {link.label}
          </a>
        ))}
        <a
          href={`mailto:${siteConfig.email}`}
          class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
        >
          <Icon name="mail" size="sm" />
          Email
        </a>
      </div>
    </CTA>
  </div>

  <Footer
    slot="footer"
    layout="stacked"
    background="secondary"
    socialLinks={socialLinks}
    showSocial={true}
    legalLinks={[
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Service', href: '/terms' },
    ]}
  />
</BaseLayout>
