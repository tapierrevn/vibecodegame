---
import type { CollectionEntry } from 'astro:content';
import siteConfig from '@/config/site.config';
import PageLayout from '@/layouts/PageLayout.astro';
import GameCard from '@/components/games/GameCard.astro';
import DeveloperCard from '@/components/developers/DeveloperCard.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import { gameEntryToPath } from '@/lib/games-similar';
import DeveloperCommunityCTA from '@/components/landing/CTA.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';

interface Props {
  name: string;
  description: string;
  creationYear: string;
  website: string;
  logo: string;
  headquarterAddress: string;
  aiTools: string[];
  gamesGenre: string[];
  gameEngine: string[];
  relatedGames: CollectionEntry<'games'>[];
  teamMembers: CollectionEntry<'developers'>[];
}

const {
  name,
  description,
  creationYear,
  website,
  logo,
  headquarterAddress,
  aiTools,
  gamesGenre,
  gameEngine,
  relatedGames,
  teamMembers,
} = Astro.props;

const pageTitle = `${name} Game Studio Profile | AI Workflow, Team & Games | ${siteConfig.name}`;
const pageDescription = `${name} studio profile: AI tools, game engines, genres, team members, and games developed by the studio.`;
const pageKeywords = [
  `${name} game studio`,
  `${name} ai game development`,
  `${name} game engine stack`,
  `${name} team members`,
  `${name} games`,
];
const fullUrl = new URL(Astro.url.pathname, Astro.site).toString();
const openGamesByDefault = relatedGames.length > 0;
const openTeamByDefault = !openGamesByDefault && teamMembers.length > 0;
---

<PageLayout title={pageTitle} description={pageDescription} keywords={pageKeywords} showScrollProgress eagerReveal>
  <section class="border-t border-border bg-background-secondary py-[var(--space-section-sm)]">
    <div class="mx-auto max-w-5xl px-6">
      <div class="rounded-2xl border border-border bg-background p-6 sm:p-8">
        <div class="flex flex-col gap-6">
          <div class="flex items-start gap-4">
            <img src={logo} alt={`${name} logo`} class="h-20 w-20 rounded-xl border border-border bg-background-secondary p-2 object-cover" loading="lazy" />
            <div>
              <h1 class="font-display text-4xl font-bold text-foreground">{name}</h1>
              <p class="mt-2 text-lg text-foreground-muted">{description}</p>
            </div>
          </div>
        </div>

        <div class="mt-6 grid gap-4 text-sm md:grid-cols-2">
          <div class="rounded-lg border border-border bg-background-secondary p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-foreground-muted">Created</p>
            <p class="mt-1 text-foreground">{creationYear}</p>
          </div>
          <div class="rounded-lg border border-border bg-background-secondary p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-foreground-muted">Headquarters</p>
            <p class="mt-1 text-foreground">{headquarterAddress}</p>
          </div>
        </div>

        <div class="mt-6 space-y-3">
          {gamesGenre.length > 0 && (
            <div>
              <p class="mb-2 text-xs font-medium text-foreground-muted">Game Genres</p>
              <div class="flex flex-wrap gap-2">
                {gamesGenre.map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}
          {aiTools.length > 0 && (
            <div>
              <p class="mb-2 text-xs font-medium text-foreground-muted">AI Tools</p>
              <div class="flex flex-wrap gap-2">
                {aiTools.map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}
          {gameEngine.length > 0 && (
            <div>
              <p class="mb-2 text-xs font-medium text-foreground-muted">Game Engines</p>
              <div class="flex flex-wrap gap-2">
                {gameEngine.map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}
        </div>

        <div class="mt-6 flex justify-end">
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 whitespace-nowrap rounded-full border border-border bg-background-secondary px-4 py-2 text-sm font-medium text-foreground hover:border-brand-500 hover:text-brand-500"
          >
            <Icon name="globe" size="sm" />
            Visit Website
          </a>
        </div>
      </div>
    </div>
  </section>

  <article class="bg-background py-[var(--space-section-sm)] border-t border-border">
    <div class="prose prose-lg mx-auto max-w-4xl px-6">
      <slot />
    </div>
  </article>

  <section class="mx-auto max-w-screen-xl px-6 border-t border-border" data-reveal>
    <details name="studio-profile-sections" class="group/accordion border-b border-border" open={openGamesByDefault}>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
        <span class="font-display text-2xl font-bold text-foreground">Games Developed by {name} ({relatedGames.length})</span>
        <Icon name="chevron-down" size="sm" class="text-foreground-muted transition-transform duration-200 group-open/accordion:rotate-180" />
      </summary>
      <div class="pt-[var(--space-stack-md)] pb-[var(--space-stack-lg)]">
        {relatedGames.length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {relatedGames.map((game) => (
              <GameCard
                title={game.data.title}
                description={game.data.description}
                href={gameEntryToPath(game)}
                developerName={game.data.developerName}
                studio={game.data.studio}
                developerProfileUrl={game.data.developerProfileUrl}
                genre={game.data.genre}
                gameEngine={game.data.gameEngine}
                aiTools={game.data.aiTools}
                communityScore={game.data.communityScore}
                playUrl={game.data.playUrl}
                publishedAt={game.data.publishedAt}
                offersPrice={game.data.offersPrice}
                gamePlatform={game.data.gamePlatform}
                image={game.data.image}
                svgSlug={game.data.svgSlug}
              />
            ))}
          </div>
        ) : (
          <p class="text-foreground-muted">No games published yet for this studio.</p>
        )}
      </div>
    </details>

    <details name="studio-profile-sections" class="group/accordion border-b border-border" open={openTeamByDefault}>
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left">
        <span class="font-display text-2xl font-bold text-foreground">Team Members ({teamMembers.length})</span>
        <Icon name="chevron-down" size="sm" class="text-foreground-muted transition-transform duration-200 group-open/accordion:rotate-180" />
      </summary>
      <div class="pt-[var(--space-stack-md)] pb-[var(--space-stack-lg)]">
        {teamMembers.length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {teamMembers.map((developer) => (
              <DeveloperCard
                name={developer.data.name}
                studio={developer.data.studio ?? ''}
                href={`/developers/${developer.id.replace('en/', '')}`}
                picture={developer.data.picture}
                preferredGenres={developer.data.preferredGenres}
                preferredAiTools={developer.data.preferredAiTools}
              />
            ))}
          </div>
        ) : (
          <p class="text-foreground-muted">No team members linked for this studio yet.</p>
        )}
      </div>
    </details>
  </section>

  <section class="bg-background py-8 border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
        <a
          href="/game-studios-using-AI"
          class="text-brand-600 hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300 inline-flex items-center gap-2 text-sm font-medium transition-colors"
        >
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Game Studios Using AI
        </a>
        <ShareButtons title={pageTitle} url={fullUrl} />
      </div>
    </div>
  </section>

  <DeveloperCommunityCTA purpose="developerCommunity" />
</PageLayout>
