---
/**
 * PageLayout
 * Layout wrapper for standard content pages (non-landing)
 * Uses Header + Footer with content page configuration
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import siteConfig from '@/config/site.config';
import { cn } from '@/lib/cn';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  showScrollProgress?: boolean;
  eagerReveal?: boolean;
  fillViewport?: boolean;
  footerClass?: string;
}

const {
  title,
  description,
  image,
  imageAlt,
  noindex,
  nofollow,
  showScrollProgress = false,
  eagerReveal = false,
  fillViewport = true,
  footerClass,
} = Astro.props;

// Map social URLs to platform format
const socialLinks = siteConfig.socialLinks.map((url) => {
  let platform = 'link';
  if (url.includes('x.com') || url.includes('twitter.com')) platform = 'twitter';
  else if (url.includes('discord.gg')) platform = 'discord';
  else if (url.includes('youtube.com')) platform = 'youtube';
  else if (url.includes('github.com')) platform = 'github';
  else if (url.includes('linkedin.com')) platform = 'linkedin';
  else if (url.includes('instagram.com')) platform = 'instagram';
  return { platform, href: url };
});

---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  eagerReveal={eagerReveal}
>
  <Header
  slot="header"
  position="fixed"
  shape="floating"
  variant="default"
  colorScheme="default"
  size="lg"
  showCta={false}
  cta={{ label: 'Get in touch', href: '/contact' }}
  showThemeSelector={false}
  showScrollProgress={true}
  scrollProgressPosition="top"
/>

  <main class={cn('pt-16', fillViewport && 'min-h-screen')}>
    <slot />
  </main>

  <Footer 
  slot="footer" 
  layout="stacked"
  class={footerClass}
  background="secondary" 
  socialLinks={socialLinks} 
  showSocial={true}
  legalLinks={[
  { label: 'Privacy Policy', href: '/privacy' },
  { label: 'Terms of Service', href: '/terms' },
]}
/>
</BaseLayout>
