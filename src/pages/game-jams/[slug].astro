---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import GameJamLayout from '@/layouts/GameJamLayout.astro';
import GameJamListing from '@/components/game-jams/GameJamListing.astro';
import {
  segmentToYear,
  yearToGameJamsPathSegment,
  assertGameJamFilterSegmentsDoNotCollideWithEventSlugs,
  GAME_JAM_STATUS_SEGMENTS,
  segmentToStatusFilter,
} from '@/lib/game-jams-filter';
import type { GameJamStatus } from '@/lib/game-jams-status';

interface EventProps {
  kind: 'event';
  event: CollectionEntry<'gameJams'>;
}

interface YearFilterProps {
  kind: 'filter';
  filterKind: 'year';
  year: number;
}

interface StatusFilterProps {
  kind: 'filter';
  filterKind: 'status';
  statusFilter: GameJamStatus;
}

type Props = EventProps | YearFilterProps | StatusFilterProps;

export async function getStaticPaths() {
  const events = await getCollection('gameJams', ({ data }) => {
    const isEn = (data.locale ?? 'en') === 'en';
    return isEn && (import.meta.env.PROD ? data.draft !== true : true);
  });

  const eventSlugs = events.map((event) => event.id.replace('en/', ''));

  const years = [...new Set(events.map((event) => event.data.startDate.getFullYear()))];
  const yearSegments = years.map((year) => yearToGameJamsPathSegment(year));

  assertGameJamFilterSegmentsDoNotCollideWithEventSlugs(eventSlugs, yearSegments);

  const eventPaths = events.map((event) => ({
    params: { slug: event.id.replace('en/', '') },
    props: { kind: 'event' as const, event } satisfies EventProps,
  }));

  const yearFilterPaths = years.map((year) => ({
    params: { slug: yearToGameJamsPathSegment(year) },
    props: { kind: 'filter' as const, filterKind: 'year' as const, year } satisfies YearFilterProps,
  }));

  const statusFilterPaths = (Object.entries(GAME_JAM_STATUS_SEGMENTS) as [GameJamStatus, string][]).map(
    ([statusFilter, segment]) => ({
      params: { slug: segment },
      props: { kind: 'filter' as const, filterKind: 'status' as const, statusFilter } satisfies StatusFilterProps,
    }),
  );

  return [...eventPaths, ...yearFilterPaths, ...statusFilterPaths];
}

const props = Astro.props as Props;

if (props.kind === 'event' && !props.event) {
  throw new Error('Game Jam event page is missing event data.');
}

const routeSlug = Astro.params.slug ?? '';

if (props.kind === 'filter' && props.filterKind === 'year') {
  const resolvedYear = segmentToYear(routeSlug);
  if (resolvedYear !== props.year) {
    throw new Error(`Game Jam year filter route mismatch for slug "${routeSlug}".`);
  }
}

if (props.kind === 'filter' && props.filterKind === 'status') {
  const resolved = segmentToStatusFilter(routeSlug);
  if (resolved !== props.statusFilter) {
    throw new Error(`Game Jam status filter route mismatch for slug "${routeSlug}".`);
  }
}

let Content: Awaited<ReturnType<typeof render>>['Content'] | null = null;
if (props.kind === 'event' && props.event) {
  ({ Content } = await render(props.event));
}
---

{
  props.kind === 'event' && props.event && Content ? (
    <GameJamLayout
      name={props.event.data.name}
      description={props.event.data.description}
      startDate={props.event.data.startDate}
      endDate={props.event.data.endDate}
      participationLink={props.event.data.participationLink}
      place={props.event.data.place}
      country={props.event.data.country}
      featured={props.event.data.featured}
      organizers={props.event.data.organizers}
      image={props.event.data.image}
      imageAlt={props.event.data.imageAlt}
    >
      <Content />
    </GameJamLayout>
  ) : props.kind === 'filter' && props.filterKind === 'year' ? (
    <GameJamListing activeYear={props.year} activeStatus={null} />
  ) : props.kind === 'filter' && props.filterKind === 'status' ? (
    <GameJamListing activeYear={null} activeStatus={props.statusFilter} />
  ) : null
}
