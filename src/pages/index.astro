---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import HomeHubGrid from '@/components/landing/HomeHubGrid.astro';
import NewsletterForm from '@/components/patterns/NewsletterForm.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';
import homeHeroVideo from '@/assets/home/vibecodegame_banner.mp4';
import homeHeroOgImage from '@/assets/home/vibecodegame.png';

/** Homepage-only SEO (see SEO.astro: rendered as `{title} — {siteConfig.name}`) */
const homeMetaTitle = 'Vibe-Coded Games, AI Tools & Game Jams';
const homeMetaDescription =
  'Browse vibe-coded and AI-built indie games, game jams, developer profiles, and AI dev tools. Play and build with the Vibecode.game community.';

function isEnEntry(data: { locale?: string }): boolean {
  return !data.locale || data.locale === 'en';
}

const games = (await getCollection('games', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))).filter(
  (e) => isEnEntry(e.data)
);
const developers = (
  await getCollection('developers', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))
).filter((e) => isEnEntry(e.data));
const aiTools = (await getCollection('aiTools', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))).filter(
  (e) => isEnEntry(e.data)
);
const gameJams = (await getCollection('gameJams', ({ data }) => (import.meta.env.PROD ? data.draft !== true : true))).filter(
  (e) => isEnEntry(e.data)
);

function countLabel(count: number, singular: string, plural: string): string {
  return `${count} ${count === 1 ? singular : plural}`;
}

const hubItems = [
  {
    href: '/vibe-coded-games',
    title: 'Vibe-coded games',
    description: 'Browse AI-built games, curated picks, genres, and tools players actually use.',
    icon: 'gamepad-2',
    meta: countLabel(games.length, 'game', 'games'),
  },
  {
    href: '/developers',
    title: 'Developer Hub',
    description: 'Meet the makers behind vibe-coded games and explore their stacks and stories.',
    icon: 'users',
    meta: countLabel(developers.length, 'profile', 'profiles'),
  },
  {
    href: '/ai-tools',
    title: 'AI tools',
    description: 'Compare coding assistants and builders to find the right workflow for your next ship.',
    icon: 'sparkles',
    meta: countLabel(aiTools.length, 'tool', 'tools'),
  },
  {
    href: '/game-jams',
    title: 'Game jams',
    description: 'Find upcoming and past jams — build fast, ship with the community, and get discovered.',
    icon: 'trophy',
    meta: countLabel(gameJams.length, 'jam', 'jams'),
  },
] as const;

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((e) => isEnEntry(e.data))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title={homeMetaTitle}
  description={homeMetaDescription}
  image={homeHeroOgImage.src}
  imageAlt="Vibecode.game — vibe-coded and AI-built games community"
  includeOrgSchema={true}
  includePersonSchema={false}
  includeProfessionalServiceSchema={false}
>
  <Hero
    layout="centered"
    size="xl"
    class="hero-dark-gradient"
    showGlow
    showGrid
    showScrollIndicator
    descriptionClass="max-w-3xl"
    backgroundVideoSrc={homeHeroVideo}
    backgroundVideoPoster={homeHeroOgImage.src}
  >
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">Play. Build. Discover.</Badge>

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">The home for</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)] dark:text-foreground dark:[-webkit-text-fill-color:currentColor]">vibe-coded games</span>
    </h1>

    <p slot="description">{siteConfig.description}</p>

    <Fragment slot="actions">
      <Button size="lg" href="/vibe-coded-games">
        Browse games
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/developers">
        <Icon name="users" size="sm" />
        Developer Hub
      </Button>
      <Button size="lg" variant="outline" href="/blog">
        <Icon name="book-open" size="sm" />
        Blog
      </Button>
    </Fragment>
  </Hero>

  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Explore</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
            Everything on {siteConfig.name}
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Jump into games, makers, tools, and jams — all in one place.
        </p>
      </div>

      <HomeHubGrid items={[...hubItems]} />
    </div>
  </section>

  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex items-end justify-between" data-reveal>
        <div class="flex flex-col gap-6">
          <Badge variant="brand" pill class="self-start">From the blog</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">Featured</h2>
        </div>
        <a
          href="/blog"
          class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors shrink-0"
        >
          View all posts
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
          />
        ))}
      </div>

      <div class="text-center sm:hidden">
        <Button variant="outline" href="/blog">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6" data-reveal>
      <Card variant="elevated" padding="lg" class="max-w-2xl mx-auto">
        <div class="flex flex-col gap-6 text-center sm:text-left sm:flex-row sm:items-center sm:justify-between sm:gap-10">
          <div class="flex-1 space-y-2">
            <Badge variant="brand" pill class="mx-auto sm:mx-0">Newsletter</Badge>
            <h2 class="font-display text-2xl md:text-3xl font-bold text-foreground text-balance">
              Get new games, jams, and guides in your inbox
            </h2>
            <p class="text-sm text-foreground-muted leading-relaxed text-balance">
              Occasional updates only — no spam. Unsubscribe anytime.
            </p>
          </div>
          <div class="flex-1 w-full min-w-0">
            <NewsletterForm
              class="text-left"
              placeholder="you@example.com"
              buttonText="Subscribe"
              successMessage="Thanks — you're on the list."
            />
          </div>
        </div>
      </Card>
    </div>
  </section>
</LandingLayout>
